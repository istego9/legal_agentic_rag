  "operative_orders": [
    {
      "item_no": 1,
      "order_text": "The First Applicant is granted permission to appeal in respect of the proposed ﬁrst ground of appeal only.",
      "order_effect_label": "permission_granted_partial",
      "page_number_1": 2
    },
    {
      "item_no": 2,
      "order_text": "The operation of the Part 50 Orders relating to the First Applicant is stayed until further order.",
      "order_effect_label": "stay_granted_partial",
      "page_number_1": 2
    },
    {
      "item_no": 3,
      "order_text": "The First Applicant shall ﬁle and serve his skeleton argument in support of the appeal within fourteen (14) days of the date of this Order.",
      "order_effect_label": "filing_direction",
      "page_number_1": 2
    },
    {
      "item_no": 4,
      "order_text": "The Judgment Creditor shall ﬁle and serve its skeleton argument in opposition to the appeal within fourteen (14) days of service of the First Applicant’s skeleton argument.",
      "order_effect_label": "filing_direction",
      "page_number_1": 2
    },
    {
      "item_no": 5,
      "order_text": "The First Applicant shall ﬁle and serve any skeleton argument in reply within ten (10) days after the service of that skeleton.",
      "order_effect_label": "filing_direction",
      "page_number_1": 2
    },
    {
      "item_no": 6,
      "order_text": "Within ten (10) days of the date of this Order, the parties shall provide to the Registry their available dates for a hearing of the appeal in the period between 45 and 140 days after the date of this Order.",
      "order_effect_label": "hearing_direction",
      "page_number_1": 2
    },
    {
      "item_no": 7,
      "order_text": "The Renewed Application by the Second and Third Applicants is dismissed.",
      "order_effect_label": "application_dismissed",
      "page_number_1": 2
    },
    {
      "item_no": 8,
      "order_text": "The Stay Application by the Second and Third Applicants is dismissed.",
      "order_effect_label": "application_dismissed",
      "page_number_1": 3
    },
    {
      "item_no": 9,
      "order_text": "The Second and Third Applicants shall pay the Judgment Creditor’s costs of their Renewed Application and of their Stay Application. In default of agreement with respect to the quantum of those costs, they will be assessed in accordance with the orders which follow.",
      "order_effect_label": "costs_payable",
      "page_number_1": 3
    },
    {
      "item_no": 10,
      "order_text": "Within twenty-eight (28) days of the date of this Order, the Judgment Creditor shall ﬁle a Statement of Costs incurred in respect of the Renewed Application and the Stay Application made by the Second and Third Applicants, together with any short submissions in support of the costs claimed.",
      "order_effect_label": "filing_direction",
      "page_number_1": 3
    },
    {
      "item_no": 11,
      "order_text": "Within fourteen (14) days of service of the Statement of Costs the Second and Third Applicants shall ﬁle and serve any submissions relating to the quantum of costs claimed.",
      "order_effect_label": "filing_direction",
      "page_number_1": 3
    },
    {
      "item_no": 12,
      "order_text": "Within seven (7) days of service of any submissions in accordance with the preceding order, the Judgment Creditor shall ﬁle any submissions in reply to those submissions.",
      "order_effect_label": "filing_direction",
      "page_number_1": 3
    },
    {
      "item_no": 13,
      "order_text": "The quantum of the costs payable pursuant to these Orders shall thereafter be assessed by the Chief Justice on the papers.",
      "order_effect_label": "assessment_direction",
      "page_number_1": 3
    }
  ],
