# Leave endpoint and key empty to keep deterministic-only mode.
LLM_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_MODE=chat_completions
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_MAX_TOKENS=256
AZURE_OPENAI_TEMPERATURE=0.0
AZURE_OPENAI_TIMEOUT_SECONDS=6.0
AZURE_OPENAI_TOP_P=1.0
AZURE_OPENAI_TRIES=1
AZURE_OPENAI_TOKEN_PARAMETER=max_tokens
AZURE_OPENAI_REASONING_EFFORT=
AZURE_OPENAI_VERBOSITY=
CORPUS_METADATA_NORMALIZER_PROVIDER=
CORPUS_METADATA_NORMALIZER_DEPLOYMENT=wf-gpt5mini-metadata
CORPUS_METADATA_NORMALIZER_API_MODE=responses
CORPUS_METADATA_NORMALIZER_MODEL=gpt-5-mini
CORPUS_METADATA_NORMALIZER_MAX_TOKENS=
CORPUS_METADATA_NORMALIZER_TIMEOUT_SECONDS=30
CORPUS_METADATA_NORMALIZER_TOKEN_PARAMETER=max_output_tokens
CORPUS_METADATA_NORMALIZER_REASONING_EFFORT=minimal
CORPUS_METADATA_NORMALIZER_VERBOSITY=low
AGENTIC_ENRICHMENT_LLM_ENABLED=0
CHUNK_SEMANTICS_PROVIDER=
CHUNK_SEMANTICS_DEPLOYMENT=wf-gpt5mini-metadata
CHUNK_SEMANTICS_API_MODE=responses
CHUNK_SEMANTICS_MODEL=gpt-5-mini
CHUNK_SEMANTICS_MAX_TOKENS=1200
CHUNK_SEMANTICS_TIMEOUT_SECONDS=30
CHUNK_SEMANTICS_TOKEN_PARAMETER=max_output_tokens
CHUNK_SEMANTICS_REASONING_EFFORT=minimal
CHUNK_SEMANTICS_VERBOSITY=low

# Switch LLM_PROVIDER=openai and fill OPENAI_API_KEY to use the direct OpenAI API instead of Azure.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_MODE=chat_completions
OPENAI_MAX_TOKENS=256
OPENAI_TEMPERATURE=0.0
OPENAI_TIMEOUT_SECONDS=6.0
OPENAI_TOP_P=1.0
OPENAI_TRIES=1
OPENAI_TOKEN_PARAMETER=max_tokens
OPENAI_REASONING_EFFORT=
OPENAI_SERVICE_TIER=
OPENAI_VERBOSITY=
