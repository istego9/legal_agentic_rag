{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoldDataset",
  "description": "Versioned gold dataset definition.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "gold_dataset_id": {
      "type": "string",
      "format": "uuid"
    },
    "project_id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "locked",
        "archived"
      ]
    },
    "base_dataset_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "question_count": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "gold_dataset_id",
    "project_id",
    "name",
    "version",
    "status",
    "question_count",
    "created_at",
    "updated_at"
  ]
}