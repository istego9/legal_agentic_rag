  "required": [
    "chunk_id",
    "document_id",
    "pdf_id",
    "page_id",
    "page_number",
    "chunk_index_on_page",
    "text_raw"
  ],
  "title": "ChunkBase",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
