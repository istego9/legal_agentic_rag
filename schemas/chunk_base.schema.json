      "type": "array"
    },
    "schedule_refs": {
      "items": {
        "type": "string"
      },
      "title": "Schedule Refs",
      "type": "array"
    },
    "law_refs": {
      "items": {
        "type": "string"
      },
      "title": "Law Refs",
      "type": "array"
    },
    "case_refs": {
      "items": {
        "type": "string"
      },
      "title": "Case Refs",
      "type": "array"
    },
    "dates": {
      "items": {
        "type": "string"
      },
      "title": "Dates",
      "type": "array"
    },
    "money_values": {
      "items": {
        "type": "string"
      },
      "title": "Money Values",
      "type": "array"
    },
    "roles": {
      "items": {
        "type": "string"
      },
      "title": "Roles",
      "type": "array"
    },
    "topic_tags": {
      "items": {
        "type": "string"
      },
      "title": "Topic Tags",
      "type": "array"
    },
    "legal_action_tags": {
      "items": {
        "type": "string"
      },
      "title": "Legal Action Tags",
      "type": "array"
    },
    "effective_start_date": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Effective Start Date"
    },
    "effective_end_date": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Effective End Date"
    },
    "is_current_version": {
      "anyOf": [
        {
