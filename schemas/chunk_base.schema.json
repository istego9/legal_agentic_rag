{
  "properties": {
    "chunk_id": {
      "title": "Chunk Id",
      "type": "string"
    },
    "document_id": {
      "title": "Document Id",
      "type": "string"
    },
    "pdf_id": {
      "title": "Pdf Id",
      "type": "string"
    },
    "page_id": {
      "title": "Page Id",
      "type": "string"
    },
    "page_number": {
      "minimum": 0,
      "title": "Page Number",
      "type": "integer"
    },
    "chunk_type": {
      "default": "paragraph",
      "enum": [
        "paragraph",
        "heading",
        "list_item",
        "table_row",
        "footnote"
      ],
      "title": "Chunk Type",
      "type": "string"
    },
    "chunk_index_on_page": {
      "minimum": 0,
      "title": "Chunk Index On Page",
      "type": "integer"
    },
    "char_start": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Char Start"
    },
    "char_end": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Char End"
    },
    "text_raw": {
      "title": "Text Raw",
      "type": "string"
    },
    "text_clean": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Text Clean"
    },
    "text_compact": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Text Compact"
    },
    "retrieval_text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Retrieval Text"
    },
    "embedding_text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Embedding Text"
    },
    "heading_path": {
      "items": {
        "type": "string"
      },
      "title": "Heading Path",
      "type": "array"
    },
    "section_kind": {
      "anyOf": [
        {
          "enum": [
            "cover",
            "heading",
            "definition",
            "operative_provision",
            "exception",
            "penalty",
            "procedure",
            "schedule_item",
            "cross_reference",
            "footnote",
            "parties",
            "procedural_history",
            "facts",
            "issues",
            "reasoning",
            "holding",
            "order",
            "disposition"
