      "anyOf": [
        {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Confidence Score"
    },
    "parser_flags": {
      "items": {
        "type": "string"
      },
      "title": "Parser Flags",
      "type": "array"
