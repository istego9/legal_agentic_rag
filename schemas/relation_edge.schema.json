    },
    "source_page_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Page Id"
    },
    "created_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created By"
    }
  },
  "required": [
    "edge_id",
    "source_object_type",
    "source_object_id",
    "target_object_type",
    "target_object_id",
    "edge_type"
