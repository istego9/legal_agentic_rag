{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QueryResponse",
  "description": "Normalized answer plus sources and debug metadata.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "question_id": {
      "type": "string"
    },
    "answer": {
      "type": [
        "string",
        "number",
        "boolean",
        "null",
        "array"
      ]
    },
    "answer_normalized": {
      "type": [
        "string",
        "null"
      ]
    },
    "answer_type": {
      "type": "string",
      "enum": [
        "boolean",
        "number",
        "date",
        "name",
        "names",
        "free_text"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "route_name": {
      "type": "string"
    },
    "abstained": {
      "type": "boolean"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/page_ref"
      }
    },
    "telemetry": {
      "$ref": "#/$defs/telemetry"
    },
    "debug": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entities": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "candidate_pages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/page_ref"
          }
        },
        "policy_version": {
          "type": "string"
        },
        "trace_url": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "policy_version"
      ]
    }
  },
  "required": [
    "question_id",
    "answer",
    "answer_type",
    "confidence",
    "route_name",
    "abstained",
    "sources",
    "telemetry"
  ],
  "$defs": {
    "page_ref": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "PageRef",
      "description": "Canonical PDF page reference used in evaluation and submission.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "type": "string",
          "format": "uuid"
        },
        "document_id": {
          "type": "string",
          "format": "uuid"
        },
        "pdf_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "page_num": {
          "type": "integer",
          "minimum": 0
        },
        "page_index_base": {
          "type": "integer",
          "enum": [
            0,
            1
          ]
        },
        "source_page_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+_[0-9]+$"
        },
        "used": {
          "type": "boolean"
        },
        "evidence_role": {
          "type": "string",
          "enum": [
            "primary",
            "supporting",
            "title",
            "lineage",
            "negative_check"
          ]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "pdf_id",
        "page_num",
        "page_index_base",
        "source_page_id",
        "used"
      ]
    },
    "telemetry": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Telemetry",
      "description": "Per-answer telemetry captured for competition submission and internal evaluation.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_started_at": {
          "type": "string",
          "format": "date-time"
        },
        "first_token_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "ttft_ms": {
          "type": "integer",
          "minimum": 0
        },
        "total_response_ms": {
          "type": "integer",
          "minimum": 0
        },
        "time_per_output_token_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "model_name": {
          "type": "string"
        },
        "route_name": {
          "type": "string"
        },
        "judge_model_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "search_profile": {
          "type": "string"
        },
        "telemetry_complete": {
          "type": "boolean"
        },
        "trace_id": {
          "type": "string"
        }
      },
      "required": [
        "request_started_at",
        "completed_at",
        "ttft_ms",
        "total_response_ms",
        "input_tokens",
        "output_tokens",
        "model_name",
        "route_name",
        "telemetry_complete"
      ]
    }
  }
}