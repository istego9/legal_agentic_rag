{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SubmissionAnswer",
  "description": "Per-question object written into competition JSON submission.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "question_id": {
      "type": "string"
    },
    "answer": {
      "type": [
        "string",
        "number",
        "boolean",
        "null",
        "array"
      ]
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._-]+_[0-9]+$"
      }
    },
    "telemetry": {
      "$ref": "#/$defs/telemetry"
    }
  },
  "required": [
    "question_id",
    "answer",
    "sources",
    "telemetry"
  ],
  "$defs": {
    "telemetry": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Telemetry",
      "description": "Per-answer telemetry captured for competition submission and internal evaluation.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_started_at": {
          "type": "string",
          "format": "date-time"
        },
        "first_token_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "ttft_ms": {
          "type": "integer",
          "minimum": 0
        },
        "total_response_ms": {
          "type": "integer",
          "minimum": 0
        },
        "time_per_output_token_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "model_name": {
          "type": "string"
        },
        "route_name": {
          "type": "string"
        },
        "judge_model_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "search_profile": {
          "type": "string"
        },
        "telemetry_complete": {
          "type": "boolean"
        },
        "trace_id": {
          "type": "string"
        }
      },
      "required": [
        "request_started_at",
        "completed_at",
        "ttft_ms",
        "total_response_ms",
        "input_tokens",
        "output_tokens",
        "model_name",
        "route_name",
        "telemetry_complete"
      ]
    }
  }
}