{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QueryRequest",
  "description": "Single question inference request.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "project_id": {
      "type": "string",
      "format": "uuid"
    },
    "question": {
      "$ref": "#/$defs/question"
    },
    "runtime_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "use_llm": {
          "type": "boolean"
        },
        "max_candidate_pages": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "max_context_paragraphs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "page_index_base_export": {
          "type": "integer",
          "enum": [
            0,
            1
          ]
        },
        "scoring_policy_version": {
          "type": "string"
        },
        "allow_dense_fallback": {
          "type": "boolean"
        },
        "return_debug_trace": {
          "type": "boolean"
        }
      },
      "required": [
        "use_llm",
        "max_candidate_pages",
        "max_context_paragraphs",
        "page_index_base_export",
        "scoring_policy_version",
        "allow_dense_fallback"
      ]
    }
  },
  "required": [
    "project_id",
    "question",
    "runtime_policy"
  ],
  "$defs": {
    "question": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Question",
      "description": "Competition or internal question unit.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "dataset_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "answer_type": {
          "type": "string",
          "enum": [
            "boolean",
            "number",
            "date",
            "name",
            "names",
            "free_text"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "public_competition",
            "private_competition",
            "internal_gold",
            "synthetic",
            "manual"
          ]
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "easy",
            "medium",
            "hard",
            "adversarial"
          ]
        },
        "route_hint": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "article_lookup",
            "single_case_extraction",
            "cross_case_compare",
            "cross_law_compare",
            "history_lineage",
            "no_answer",
            null
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "required": [
        "id",
        "question",
        "answer_type"
      ]
    }
  }
}